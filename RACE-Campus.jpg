  WPBakery Raw HTML Element — paste everything below this comment block
  into a "Raw HTML" element in WPBakery Page Builder.

  Notes:
  - CSS is scoped under .research-cards-wrap so it won't affect the rest of your site.
  - All 6 cards included exactly as in the original.
  - Image URLs point to the original race.reva.edu.in assets — replace if needed.
-->

<style>
   
  .research-cards-wrap *{margin:0;padding:0;box-sizing:border-box;}

  .research-cards-wrap{
    color:#F5F3EE;
    font-family:'Roboto', Arial, sans-serif;
    -webkit-font-smoothing:antialiased;
    padding: 0!important;
}
  

  .research-cards-wrap .grid{
    display:grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .research-cards-wrap .card{
    position:relative;
    width: 100%;
    aspect-ratio: 7/9.2 !important;
    border-radius: 4px;
    overflow:hidden;
    text-decoration:none;
    color:#F5F3EE;
    isolation:isolate;
    cursor:pointer;
    display:block;
    box-shadow: 0 0px 0px 0px rgba(0,0,0,0.6) !important;

  }

  /* solid panel revealed behind the sliding image */
  .research-cards-wrap .card-panel{
    position:absolute;
    inset:0;
    background: linear-gradient(160deg, #1c1430 0%, #100c1c 100%);
    z-index:0;
  }

  /* background image layer */
  .research-cards-wrap .card-bg{
    position:absolute;
    inset:0;
    background-size: cover;
    background-position:center;
    transform: translate(0, 0);
    transition: transform 0.8s cubic-bezier(.16,1,.3,1), filter 0.6s ease;
    filter: saturate(1) brightness(1);
    z-index:1;
  }
  .research-cards-wrap .card:hover .card-bg{
    transform: translate(-10%, -60%);
    filter: saturate(1.05) brightness(0.9);
  }

  .research-cards-wrap .card-bg::after{
    content:'';
    position:absolute;
    inset:0;
    background:
      repeating-linear-gradient(
        0deg,
        rgba(120,180,255,0.05) 0px,
        rgba(120,180,255,0.05) 1px,
        transparent 1px,
        transparent 4px
      );
    opacity:0;
    transition: opacity 0.6s ease;
  }
  .research-cards-wrap .card:hover .card-bg::after{ opacity:1; }

  /* gradient overlay for text legibility */
  .research-cards-wrap .card-overlay{
    position:absolute;
    inset:0;
    background: linear-gradient(
      to bottom,
      rgba(10,8,18,0.55) 0%,
      rgba(10,8,18,0.15) 35%,
      rgba(10,8,18,0.05) 55%,
      rgba(10,8,18,0.65) 100%
    );
    z-index:2;
    transition: opacity 0.6s ease, background 0.6s ease;
  }
  .research-cards-wrap .card:hover .card-overlay{
    opacity:1;
    background: linear-gradient(
      to bottom,
      rgba(11,18,32,0.92) 0%,
      rgba(11,18,32,0.88) 50%,
      rgba(11,18,32,0.94) 100%
    );
  }

  /* border frame */
  .research-cards-wrap .card::before{
    content:'';
    position:absolute;
    inset:14px;
    border:1px solid transparent;
    z-index:3;
    pointer-events:none;
    transition: border-color 0.5s ease;
  }
  .research-cards-wrap .card:hover::before{
    border-color: rgba(245,243,238,0.18);
  }

  .research-cards-wrap .card-content{
    position:relative;
    z-index:3;
    padding: 2.4rem 2.2rem;
    height:100%;
    display:flex;
    flex-direction:column;
  }

  .research-cards-wrap .card-tag{
    font-size:0.78rem;
    font-weight:700;
    letter-spacing:0.18em;
    text-transform:uppercase;
    color: #F5F3EE;
    opacity:0;
    transform: translateY(14px);
    animation: rrcRiseIn 0.7s 0.1s cubic-bezier(.16,1,.3,1) forwards;
  }

  .research-cards-wrap .card h2{
    margin-top: 1.6rem;
    font-weight:700;
      font-family:'Roboto', Arial, sans-serif!important;
    font-size: 36px;
    line-height:1.0;
    max-width: 18ch;
    color: #fff!important;
    opacity:0;
    transform: translateY(18px);
    animation: rrcRiseIn 0.8s 0.28s cubic-bezier(.16,1,.3,1) forwards;
    transition: transform 0.6s cubic-bezier(.16,1,.3,1) 0.15s;
  }
  .research-cards-wrap .card:hover h2{
    transform: translateY(-4px) translateX(0);
  }

  .research-cards-wrap .card h2 .sub-title{
    font-size: 20px !important;
      font-family:'Roboto', Arial, sans-serif!important;
    font-weight: 400;
    display: inline-block;
    margin-bottom: 0.2rem;
    opacity: 0.9;
    color: #fff!important;
  }

    .research-cards-wrap .prog-badge-pill {
         display: inline-flex;
        margin-top: 1.1rem;
        align-items: center;
    width: fit-content;
        font-size: 12px;
        font-weight:400;
        padding:3px 10px;
        border-radius:100px;
       background: rgba(0, 0, 0, 0.7);
        border: 0.5px solid rgba(255, 255, 255, 0.9);
        color:#fff;
        opacity:0;
    transform:translateX(40px);
    transition:
        opacity .5s ease,
        transform .6s cubic-bezier(.16,1,.3,1);
    }

    .research-cards-wrap .card:hover .prog-badge-pill{
   opacity:1;
    transform:translateX(0);;
    
  }
    
     
    
  /* description, hidden until hover */
  .research-cards-wrap .card-desc{
    margin-top: 1rem;
    font-size: 14px;
      border-left:2px solid #fff;
      padding-left: 5px;
    line-height:1.2;
color: rgba(255, 255, 255, 1);
      max-width: 30ch;
     opacity:0;
    transform:translateX(40px);
    transition:
        opacity .5s ease,
        transform .6s cubic-bezier(.16,1,.3,1);
  }
  .research-cards-wrap .card:hover .card-desc{
    opacity:1;
    transform: translateX(0);
  }
    

    .research-cards-wrap .prog-meta {
    margin-top:15px;
    display:grid;
    grid-template-columns:repeat(2,150px);
    gap:.75rem;
    opacity:0;
    transform:translateX(40px);
    transition:
        opacity .5s ease,
        transform .6s cubic-bezier(.16,1,.3,1);

}
    
    .research-cards-wrap .card:hover .prog-meta{
    opacity:1;
    transform:translateX(0);
}
    
   .research-cards-wrap .prog-meta-label{font-family:'Roboto', Arial, sans-serif!important; font-size:.6rem; color: #fff; text-transform:uppercase;letter-spacing:.06em;margin-bottom:1px; opacity:0;
    transform:translateX(40px);
    transition:
        opacity .5s ease,
        transform .6s cubic-bezier(.16,1,.3,1);
}
.research-cards-wrap .prog-meta-val{font-size:.82rem;font-weight:600;color: #fff; opacity:0;
    transform:translateX(40px);
    transition:
        opacity .5s ease,
        transform .6s cubic-bezier(.16,1,.3,1);
}
    
    
.research-cards-wrap .card:hover .prog-meta-label,
.research-cards-wrap .card:hover .prog-meta-val{
    opacity:1;
    transform:translateX(0);
}
    
    
  /* arrow / button that appears on hover */
  .research-cards-wrap .card-btn{
    margin-top:auto;
    display:inline-flex;
    align-items:center;
    gap:8px;
    padding:12px 22px;
    border:none;
    border-radius:4px;
    background:#ff6b00;
    color:#fff;
    font-size:0.85rem;
    font-weight:600;
    letter-spacing:0.04em;
    text-transform:uppercase;
    opacity:0;
    transform:translateY(10px);
    transition:all .4s ease;
    width: fit-content;
  }

  .research-cards-wrap .card:hover .card-btn{
    opacity:1;
    transform:translateY(0);
    background:#ff7f26;
  }

  @keyframes rrcRiseIn{
    to{ opacity:1; transform: translateY(0); }
  }

  /* ambient glow that drifts on hover */
  .research-cards-wrap .glow{
    position:absolute;
    width:260px; height:260px;
    border-radius:50%;
    background: radial-gradient(circle, rgba(124,255,178,0.25), transparent 70%);
    filter: blur(50px);
    top:-60px; right:-60px;
    z-index:1;
    opacity:0;
    transition: opacity 0.6s ease, transform 1.4s cubic-bezier(.16,1,.3,1);
    transform: translate(0,0);
  }
  .research-cards-wrap .card:hover .glow{
    opacity:0.6;
    transform: translate(-30px, 40px);
  }

  /* ===== TABLET: 2 columns ===== */
  @media (max-width: 1024px){
    .research-cards-wrap .grid{
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* ===== MOBILE: 2 columns, content always visible (no hover needed) ===== */
  @media (max-width: 640px){
    .research-cards-wrap{ padding: 1.5rem; }

    .research-cards-wrap .grid{
      grid-template-columns: repeat(1, 1fr);
      gap: 1rem;
    }

    .research-cards-wrap .card{
       aspect-ratio: auto;
  min-height: 350px;
    }

    .research-cards-wrap .card-content{
      padding: 1.4rem 1.4rem;
    }

    .research-cards-wrap .card-tag{
      font-size:14px;
      letter-spacing:0.12em;
      opacity:1;
      transform:none;
      animation:none;
    }

    .research-cards-wrap .card h2{
      font-size: 32px;
      margin-top: 0.8rem;
      opacity:1;
      transform:none;
      animation:none;
      max-width: none;
    }
      
      .research-cards-wrap .card-desc{
  max-height: none;
  opacity: 1;
  transform: none;
  margin-top: 1.1rem;
}

      .research-cards-wrap .prog-badge-pill{
  max-height: none;
  opacity: 1;
  transform: none;
  margin-top: 1.1rem;
}
      
    .research-cards-wrap .card h2 .sub-title{
      font-size: 18px !important;
    }

    /* always show overlay + button on mobile */
    .research-cards-wrap .card-overlay{
      opacity:1;
      background: linear-gradient(
        to bottom,
        rgba(11,18,32,0.55) 0%,
        rgba(11,18,32,0.35) 45%,
        rgba(11,18,32,0.92) 100%
      );
    }

    .research-cards-wrap .card::before{
      border-color: rgba(245,243,238,0.18);
    }

    .research-cards-wrap .card-btn{
      opacity:1;
      transform:none;
      padding: 10px 16px;
      font-size: 0.72rem;
      margin-top:auto;
        margin-bottom:10px;
    }

    .research-cards-wrap .card:hover .card-bg{
      transform: none;
    }
  }

  @media (prefers-reduced-motion: reduce){
    .research-cards-wrap *, .research-cards-wrap *::before, .research-cards-wrap *::after{
      animation-duration: 0.01ms !important;
      transition-duration: 0.01ms !important;
    }
  }
</style>

