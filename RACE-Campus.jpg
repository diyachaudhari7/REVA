<!-- ======================== STYLES ======================== -->
<style>
/* -------------------------------------------------------
   All selectors prefixed .race-programs to avoid conflicts
   with WPBakery or theme styles.
------------------------------------------------------- */

/* Viewport meta — add to <head> if not already present in theme:
   <meta name="viewport" content="width=device-width, initial-scale=1"> */

.race-programs {
  width: 100%;
  /* Ensure content doesn't bleed on mobile */
  overflow-x: hidden;
}

.race-programs *,
.race-programs *::before,
.race-programs *::after {
  box-sizing: border-box;
}

/* ---- Inner container ---- */
.race-programs__inner {
  max-width: 1080px;
  margin: 0 auto;
  padding: 0 20px;
}

/* ================================================
   TAB SWITCHER
   Default (desktop): 4 columns
   ≤900px: 2×2 grid
   ≤480px: horizontal scroll strip
================================================ */
.race-programs .race-switcher {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8px;
  border-bottom: 1px solid #E7E2D8;
  margin-bottom: 16px;
  list-style: none;
  padding: 0;
  /* Prevent horizontal overflow on mobile */
  overflow: hidden;
}


.race-programs a.button, a.tp-button, button, input[type="submit"], input[type="reset"], input[type="button"] {
    display: inline-block;
    padding: 11px 20px;
    margin-bottom: 0px;
    cursor: pointer;
    margin-right: 7px;
    border: 0;
    border-radius: 5px;
    position: relative;
    overflow: hidden;
    box-shadow: inset 0 0 0 1px rgba(0, 0, 0, .03), inset 0px 4px 3px -2px rgba(0, 0, 0, .07);
}
.race-programs .race-switcher__item {
  background: none;
  border: none;
  cursor: pointer;
  /* Increased padding for ≥44px touch target */
  padding: 8px 8px 8px;
  min-height: 44px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  position: relative;
  font-family: 'Roboto', sans-serif;
  border-radius: 8px 8px 0 0;
  box-shadow: none;
  outline: none;
  text-align: center;
  /* Prevent text from overflowing on small screens */
  word-break: break-word;
  hyphens: auto;
  /* Smooth tap feedback */
  -webkit-tap-highlight-color: rgba(240, 113, 47, 0.1);
  touch-action: manipulation;
}

.race-programs .race-switcher__item:hover {
  background: rgba(232, 99, 44, 0.06);
}

.race-programs .race-switcher__item:focus-visible {
  outline: 2px solid #f0712f;
  outline-offset: 2px;
}

/* Active underline indicator */
.race-programs .race-switcher__item::after {
  content: "";
  position: absolute;
  left: 12%;
  right: 12%;
  bottom: 0;
  height: 3px;
  background: #f0712f;
  border-radius: 3px 3px 0 0;
  transform: scaleX(0);
  transition: transform 0.25s ease;
}

.race-programs .race-switcher__item.is-active::after {
  transform: scaleX(1);
}

.race-programs .race-switcher__figure {
  font-family: 'Roboto', sans-serif;
  /* Fluid type: shrinks on small screens */
  font-size: clamp(1.3rem, 3.6vw, 2.4rem);
  font-weight: 800;
  line-height: 1;
  color: #5B6472;
  transition: color 0.2s ease;
}

.race-programs .race-switcher__item.is-active .race-switcher__figure {
  color: #15213A;
}

.race-programs .race-switcher__label {
  font-size: clamp(0.7rem, 1.8vw, 0.82rem);
  font-weight: 600;
  color: #5B6472;
  text-align: center;
  text-decoration: none;
  line-height: 1.3;
}

.race-programs .race-switcher__item.is-active .race-switcher__label {
  color: #f0712f;
}

/* ================================================
   PANELS
   Default: 2-column grid (copy | chart)
   ≤900px: single column (copy then chart)
================================================ */
.race-programs .race-panel {
  display: none;
}

.race-programs .race-panel.is-active {
  display: grid;
  grid-template-columns: 1.3fr 1fr;
  gap: 40px;
  background: #FFFFFF;
  border: 1px solid #E7E2D8;
  border-radius: 18px;
  padding: clamp(20px, 4vw, 40px);
  animation: race-fade 0.35s ease;
}

@keyframes race-fade {
  from { opacity: 0; transform: translateY(6px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* Panel copy */
.race-programs .race-panel__eyebrow {
  font-family: 'Roboto', sans-serif;
  font-size: 0.75rem;
  font-weight: 700;
  line-height: 1;
  letter-spacing: 0.07em;
  text-transform: uppercase;
  color: #f0712f;
  margin: 0 0 8px;
}

.race-programs .race-panel__title {
  font-family: 'Roboto', sans-serif;
  font-size: clamp(1.1rem, 2.2vw, 1.5rem);
  font-weight: 700;
  line-height: 1.25;
  margin: 0 0 12px;
  color: #15213A;
}

.race-programs .race-panel__desc {
  font-family: 'Roboto', sans-serif;
  font-size: clamp(0.875rem, 2vw, 0.98rem);
  line-height: 1.2;
  color: #5B6472;
  margin: 0 0 20px;
  /* Remove ch limit on mobile so text fills the column */
  max-width: 38ch;
}

/* Chips */
.race-programs .race-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 24px;
}

.race-programs .race-chip {
  font-family: 'Roboto', sans-serif;
  font-size: clamp(0.78rem, 2vw, 0.85rem);
  color: #15213A;
  background: #FBE6D9;
  padding: 6px 12px;
  border-radius: 999px;
  /* Prevent chips from overflowing */
  white-space: nowrap;
}

.race-programs .race-chip strong {
  color: #f0712f;
}

/* CTA Button */
.race-programs .race-cta {
  font-family: 'Roboto', sans-serif;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  background: #f0712f;
  color: #fff !important;
  font-weight: 700;
  font-size: 0.95rem;
  text-decoration: none !important;
  padding: 13px 22px;
  border-radius: 999px;
  transition: background 0.2s ease, transform 0.2s ease;
  border: none;
  cursor: pointer;
  /* Ensure minimum touch target height */
  min-height: 48px;
  touch-action: manipulation;
  -webkit-tap-highlight-color: transparent;
}

.race-programs .race-cta:hover {
  background: #d9601f;
  transform: translateY(-1px);
  color: #fff !important;
}

.race-programs .race-cta:active {
  transform: translateY(0);
}

.race-programs .race-cta:focus-visible {
  outline: 2px solid #15213A;
  outline-offset: 2px;
}

/* Chart card */
.race-programs .race-panel__chart {
  background: #FAF7F3;
  border: 1px solid #E7E2D8;
  border-radius: 14px;
  padding: clamp(16px, 3vw, 22px);
  align-self: start;
}

.race-programs .race-panel__chart-label {
  font-family: 'Roboto', sans-serif;
  font-size: 0.78rem;
  font-weight: 700;
  line-height: 1;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: #5B6472;
  margin: 0 0 18px;
}

/* Bar rows */
.race-programs .race-bar {
  display: grid;
  grid-template-columns: 80px 1fr 52px;
  align-items: center;
  gap: 8px;
  margin-bottom: 14px;
}

.race-programs .race-bar:last-child {
  margin-bottom: 0;
}

.race-programs .race-bar__label {
  font-family: 'Roboto', sans-serif;
  font-size: 0.8rem;
  color: #5B6472;
  /* Prevent label overflow */
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.race-programs .race-bar__track {
  background: #FBE6D9;
  border-radius: 999px;
  height: 8px;
  overflow: hidden;
  /* Ensure track doesn't shrink to nothing */
  min-width: 40px;
}

.race-programs .race-bar__fill {
  display: block;
  height: 100%;
  width: 0;
  background: #f0712f;
  border-radius: 999px;
  transition: width 0.7s ease;
}

.race-programs .race-bar__value {
  font-family: 'Roboto', sans-serif;
  font-size: 0.8rem;
  font-weight: 700;
  color: #15213A;
  text-align: right;
  white-space: nowrap;
}

/* Trust bar */
.race-programs .race-programs__trust {
  font-family: 'Roboto', sans-serif;
  text-align: center;
  font-size: 0.85rem;
  color: #5B6472;
  margin: 28px 0 0;
  /* Allow trust bar to wrap gracefully */
  line-height: 1.8;
}

/* ================================================
   BREAKPOINTS
   900px — tablet: 2×2 tab grid, stacked panel
   600px — mobile: tighter sizing all round
   480px — small mobile: horizontal-scroll tabs
   380px — very small: micro adjustments
================================================ */

/* ---- Tablet: ≤ 900px ---- */
@media (max-width: 900px) {
  .race-programs .race-switcher {
    grid-template-columns: repeat(2, 1fr);
    row-gap: 0;
    column-gap: 8px;
  }

  /* Bottom two items keep border-bottom flush with divider */
  .race-programs .race-switcher__item:nth-child(n+3) {
    padding-bottom: 18px;
  }

  .race-programs .race-panel.is-active {
    grid-template-columns: 1fr;
    gap: 24px;
  }

  .race-programs .race-panel__desc {
    max-width: none;
  }
}

/* ---- Mobile: ≤ 600px ---- */
@media (max-width: 600px) {
  .race-programs__inner {
    padding: 0 16px;
  }

  .race-programs .race-switcher {
    grid-template-columns: repeat(2, 1fr);
    gap: 0 6px;
    margin-bottom: 20px;
  }

  .race-programs .race-switcher__item {
    padding: 10px 4px 16px;
  }

  .race-programs .race-panel.is-active {
    padding: 20px 16px;
    gap: 20px;
    border-radius: 14px;
  }

  .race-programs .race-panel__title {
    font-size: 1.1rem;
  }

  /* Full-width CTA on mobile for easier tapping */
  .race-programs .race-cta {
    width: 100%;
    font-size: 0.9rem;
  }

  .race-programs .race-bar {
    grid-template-columns: 68px 1fr 46px;
    gap: 7px;
    margin-bottom: 12px;
  }

  .race-programs .race-bar__label {
    font-size: 0.75rem;
  }

  .race-programs .race-bar__value {
    font-size: 0.75rem;
  }

  .race-programs .race-programs__trust {
    font-size: 0.78rem;
    line-height: 1.9;
  }
}

/* ---- Small mobile: ≤ 480px — switch to scrollable strip ---- */
@media (max-width: 480px) {
  .race-programs .race-switcher {
    /* Horizontal scroll strip */
    display: flex;
    flex-direction: row;
    overflow-x: auto;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;           /* Firefox */
    -ms-overflow-style: none;        /* IE/Edge */
    gap: 0;
    border-bottom: 1px solid #E7E2D8;
    /* Bleed to section edges for full-width feel */
    margin-left: -16px;
    margin-right: -16px;
    padding: 0 16px;
    width: calc(100% + 32px);
    margin-bottom: 20px;
  }

  /* Hide scrollbar track on Chrome/Safari */
  .race-programs .race-switcher::-webkit-scrollbar {
    display: none;
  }

  .race-programs .race-switcher__item {
    flex: 0 0 auto;
    /* Fixed width so 4 tabs are partially visible, hinting scroll */
    width: 120px;
    padding: 8px 8px 16px;
  }

  .race-programs .race-switcher__figure {
    font-size: clamp(1.1rem, 5vw, 1.5rem);
  }

  .race-programs .race-switcher__label {
    font-size: 0.72rem;
  }

  /* Restore inner padding since switcher bleeds */
  .race-programs .race-panel.is-active {
    padding: 16px;
  }
}

/* ---- Very small: ≤ 380px ---- */
@media (max-width: 380px) {
  .race-programs .race-switcher__item {
    width: 105px;
  }

  .race-programs .race-switcher__figure {
    font-size: 1.05rem;
  }

  .race-programs .race-chips {
    gap: 7px;
  }

  .race-programs .race-chip {
    font-size: 0.75rem;
    padding: 5px 10px;
  }

  .race-programs .race-bar {
    grid-template-columns: 60px 1fr 44px;
    gap: 6px;
  }
}

/* ---- Reduced-motion ---- */
@media (prefers-reduced-motion: reduce) {
  .race-programs .race-bar__fill,
  .race-programs .race-switcher__item::after,
  .race-programs .race-cta {
    transition: none;
  }

  .race-programs .race-panel.is-active {
    animation: none;
  }
}
</style>
<!-- ====================== END STYLES ====================== -->


<!-- ====================== JAVASCRIPT ====================== -->
<script>
(function () {
  'use strict';

  function init() {
    var section = document.querySelector('.race-programs');
    if (!section) return;

    var tabs         = section.querySelectorAll('.race-switcher__item');
    var panels       = section.querySelectorAll('.race-panel');
    var reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    /* ---- Activate a panel ---- */
    function activate(targetId) {
      tabs.forEach(function (t) {
        var active = t.dataset.target === targetId;
        t.classList.toggle('is-active', active);
        t.setAttribute('aria-selected', String(active));
      });
      panels.forEach(function (p) {
        var active = p.id === targetId;
        p.classList.toggle('is-active', active);
        if (active) animateBars(p);
      });

      /* Scroll active tab into view on the horizontal strip (≤480px) */
      var activeTab = section.querySelector('.race-switcher__item.is-active');
      if (activeTab && activeTab.scrollIntoView) {
        activeTab.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'nearest' });
      }
    }

    /* ---- Animate progress bars ---- */
    function animateBars(panel) {
      var fills = panel.querySelectorAll('.race-bar__fill');
      fills.forEach(function (fill) {
        var target = fill.dataset.width + '%';
        fill.style.width = '0%';
        requestAnimationFrame(function () {
          requestAnimationFrame(function () {
            fill.style.width = target;
          });
        });
      });
    }

    /* ---- Count-up animation ---- */
    function countUp(el) {
      var end = parseInt(el.dataset.count, 10);
      if (reduceMotion || isNaN(end)) {
        el.textContent = '\u20B9' + end + 'L';
        return;
      }
      var duration  = 900;
      var startTime = null;

      function step(timestamp) {
        if (!startTime) startTime = timestamp;
        var progress = Math.min((timestamp - startTime) / duration, 1);
        var eased    = 1 - Math.pow(1 - progress, 3);
        var value    = Math.round(end * eased);
        el.textContent = '\u20B9' + value + 'L';
        if (progress < 1) requestAnimationFrame(step);
      }
      requestAnimationFrame(step);
    }

    /* ---- Tab click ---- */
    tabs.forEach(function (tab) {
      tab.addEventListener('click', function () {
        activate(tab.dataset.target);
      });

      /* Keyboard navigation */
      tab.addEventListener('keydown', function (e) {
        var allTabs = Array.from(tabs);
        var idx     = allTabs.indexOf(tab);
        var next    = null;

        if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {
          next = allTabs[(idx + 1) % allTabs.length];
        } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
          next = allTabs[(idx - 1 + allTabs.length) % allTabs.length];
        } else if (e.key === 'Home') {
          next = allTabs[0];
        } else if (e.key === 'End') {
          next = allTabs[allTabs.length - 1];
        }

        if (next) {
          e.preventDefault();
          next.focus();
          activate(next.dataset.target);
        }
      });
    });

    /* ---- Intersection observer — trigger on scroll into view ---- */
    var figures = section.querySelectorAll('.race-switcher__figure');
    var counted = false;

    if ('IntersectionObserver' in window) {
      var observer = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting && !counted) {
            counted = true;
            figures.forEach(countUp);
            var activePanel = section.querySelector('.race-panel.is-active');
            if (activePanel) animateBars(activePanel);
          }
        });
      }, { threshold: 0.2 });  /* Lower threshold — more of section is off-screen on mobile */

      observer.observe(section);
    } else {
      figures.forEach(countUp);
      var activePanel = section.querySelector('.race-panel.is-active');
      if (activePanel) animateBars(activePanel);
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
}());
</script>
<!-- ==================== END JAVASCRIPT ==================== -->

		</div>
	</div>

	<div class="wpb_text_column wpb_content_element " >
