<section class="race-programs" aria-labelledby="race-programs-heading">
  <div class="race-programs__inner">

    <!-- Tab Switcher -->
    <div class="race-switcher" role="tablist" aria-label="Choose a program by average salary">

      <button class="race-switcher__item is-active" role="tab" aria-selected="true"
              aria-controls="panel-ba" id="tab-ba" data-target="panel-ba">
        <span class="race-switcher__figure" data-count="39">&#x20B9;0L</span>
        <span class="race-switcher__label">Business Analytics</span>
      </button>

      <button class="race-switcher__item" role="tab" aria-selected="false"
              aria-controls="panel-cyber" id="tab-cyber" data-target="panel-cyber">
