/* ─── Scoped to .race-hero only — safe inside WordPress ─── */

  .race-hero *,
  .race-hero *::before,
  .race-hero *::after {
    box-sizing: border-box !important;
  }

  /* ── Section wrapper ── */
  .race-hero {
    position: relative !important;
    width: 100% !important;
    min-height: 520px !important;
    display: flex !important;
    align-items: center !important;
    overflow: hidden !important;
    background: #0d0d0d !important;
    margin: 0 !important;
    padding: 0 !important;
  }

  /* ── Background video ── */
  .race-hero .rh-video {
    position: absolute !important;
    top: 0 !important; left: 0 !important;
    right: 0 !important; bottom: 0 !important;
    width: 100% !important;
    height: 100% !important;
    object-fit: cover !important;
    opacity: 0.55 !important;
    pointer-events: none !important;
    z-index: 0 !important;
  }

  /* ── Overlay ── */
  .race-hero .rh-overlay {
    position: absolute !important;
    top: 0 !important; left: 0 !important;
    right: 0 !important; bottom: 0 !important;
    background: linear-gradient(
      to right,
      rgba(0,0,0,0.96) 0%,
      rgba(0,0,0,0.88) 30%,
      rgba(0,0,0,0.60) 55%,
      rgba(0,0,0,0.08) 100%
    ) !important;
    z-index: 1 !important;
  }

  /* ── Inner content wrapper ── */
  .race-hero .rh-content {
    position: relative !important;
    z-index: 2 !important;
    display: flex !important;
    align-items: center !important;
    justify-content: flex-start !important;
    width: 100% !important;
    max-width: 1280px !important;
    margin: 0px !important;
    padding: 60px 48px 60px 80px !important;
    float: none !important;
  }

  /* ── Copy block ── */
  .race-hero .rh-copy {
    flex: 0 0 60% !important;
    max-width: 700px !important;
    width: 60% !important;
    text-align: left !important;
    float: none !important;
    margin: 0 !important;
    padding: 0 !important;
    animation: rhFadeInLeft 0.9s ease both !important;
  }

  @keyframes rhFadeInLeft {
    from { opacity: 0; transform: translateX(-30px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  /* ── Big heading ── */
  .race-hero .rh-copy .rh-heading {
    font-family: 'Bebas Neue', sans-serif !important;
    font-size: 70px !important;
    line-height: 0.9 !important;
    letter-spacing: 1px !important;
    text-transform: uppercase !important;
    color: #ffffff !important;
    margin: 0 0 20px 0 !important;
    padding: 0 !important;
    text-align: left !important;
    display: block !important;
    float: none !important;
    width: auto !important;
    max-width: 100% !important;
    background: none !important;
    border: none !important;
    box-shadow: none !important;
  }

  /* ── Programs line ── */
  .race-hero .rh-copy .rh-programs {
    font-family: 'Roboto Slab', sans-serif !important;
    font-size: 20px !important;
    line-height: 1.2 !important;
    color: #ffffff !important;
    margin: 0 0 24px 0 !important;
    padding: 0 !important;
    text-align: left !important;
    display: block !important;
    float: none !important;
  }

  .race-hero .rh-copy .rh-programs strong {
    color: #ffffff !important;
    font-weight: 600 !important;
    background: none !important;
  }

  .race-hero .rh-copy .rh-programs .rh-highlight {
    color: #e8521a !important;
    font-weight: 600 !important;
    background: none !important;         /* ← removes any WP highlight background */
    padding: 0 !important;
    border-radius: 0 !important;
    display: inline !important;
  }

  /* ── Tagline ── */
  .race-hero .rh-copy .rh-tagline {
    font-family: 'Roboto', sans-serif !important;
    font-size: 16px !important;
    color: #fff !important;
    margin: 0 0 40px 0 !important;
    padding: 0 !important;
    line-height: 1.2 !important;
    text-align: left !important;
    display: block !important;
    float: none !important;
  }

  /* ── Seats row ── */
  .race-hero .rh-copy .rh-seats {
    display: flex !important;
    align-items: center !important;
    gap: 8px !important;
    margin: 0 0 20px 0 !important;
    padding: 0 !important;
    font-size: 24px !important;
    color: #fff !important;
    text-align: left !important;
    float: none !important;
    list-style: none !important;
    justify-content: flex-start !important;
  }

  /* ── CTA button ── */
  .race-hero .rh-copy .rh-cta {
    display: inline-flex !important;
    align-items: center !important;
    gap: 10px !important;
    background: transparent !important;
    border: 2px solid #e8521a !important;
    color: #e8521a !important;
    padding: 13px 28px !important;
    border-radius: 4px !important;
    font-family: 'roboto', sans-serif !important;
    font-size: 18px !important;
    font-weight: 500 !important;
    text-decoration: none !important;
    cursor: pointer !important;
    transition: background 0.25s, color 0.25s !important;
    letter-spacing: 0.3px !important;
    float: none !important;
    width: auto !important;
    margin: 0 !important;
    text-align: left !important;
    box-shadow: none !important;
    outline: none !important;
  }

  .race-hero .rh-copy .rh-cta:hover {
    background: #e8521a !important;
    color: #ffffff !important;
  }

  .race-hero .rh-copy .rh-cta .rh-arrow {
    font-size: 16px !important;
    color: inherit !important;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .race-hero .rh-content {
      flex-direction: column !important;
      padding: 40px 24px !important;
    }
    .race-hero .rh-copy {
      flex: 0 0 100% !important;
      max-width: 100% !important;
      width: 100% !important;
    }
    .race-hero .rh-copy .rh-heading {
      font-size: 58px !important;
    }
    
    .race-hero .rh-video {
    display: none !important;
  }
  .race-hero {
    background: #0d0d0d !important;
  }
  }



