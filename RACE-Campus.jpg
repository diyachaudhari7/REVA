        <span class="race-switcher__label">Artificial Intelligence</span>
      </button>

      <button class="race-switcher__item" role="tab" aria-selected="false"
              aria-controls="panel-cloud" id="tab-cloud" data-target="panel-cloud">
        <span class="race-switcher__figure" data-count="24">&#x20B9;0L</span>
        <span class="race-switcher__label">Cloud Architecture &amp; Security</span>
      </button>

    </div><!-- /.race-switcher -->

    <!-- Panels -->
    <div class="race-panels">

      <!-- Business Analytics -->
      <article class="race-panel is-active" id="panel-ba" role="tabpanel" aria-labelledby="tab-ba">
        <div class="race-panel__copy">
          <p class="race-panel__eyebrow">Business Analytics</p>
          <h3 class="race-panel__title">M.Sc. in Business Analytics</h3>
          <p class="race-panel__desc">Turn raw data into board-level decisions, with AWS Academy and Microsoft Azure built into the curriculum.</p>
          <div class="race-chips">
            <span class="race-chip"><strong>354%</strong> avg. hike</span>
            <span class="race-chip"><strong>&#x20B9;4.8L</strong> programme fee</span>
            <span class="race-chip"><strong>UGC</strong> approved</span>
          </div>
          <a class="race-cta" href="https://race.reva.edu.in/pg-diploma-msc-in-business-analytics/">Explore the programme <span aria-hidden="true">&rarr;</span></a>
        </div>
        <div class="race-panel__chart" aria-hidden="true">
          <p class="race-panel__chart-label">Career outcomes</p>
          <div class="race-bar">
            <span class="race-bar__label">Avg. salary</span>
            <span class="race-bar__track"><span class="race-bar__fill" data-width="97.5"></span></span>
            <span class="race-bar__value">&#x20B9;39L</span>
          </div>
          <div class="race-bar">
            <span class="race-bar__label">Avg. hike</span>
            <span class="race-bar__track"><span class="race-bar__fill" data-width="88.5"></span></span>
