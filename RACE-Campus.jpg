	0%{		color: #000;	background-color: #fff;}
	25%{	color: #fff;background-color: #f0712f;	}
	50%{	color: #000; background-color: #fff;	}
	75%{	color:#fff;background-color: #f0712f;	}
	100%{	color: #000;background-color: #fff;	}
	
}    
