@media (max-width: 767px) {
.counter1 .counter {
   padding-top: 30px;
   padding-bottom: 30px;
    background-image: none;margin-bottom:0px;
}
}

@media (max-width: 767px) {
.counter1 .desc_wrapper .title {
        font-size: 18px;
        line-height: 5px;
        font-family: "Roboto Slab";
        color: black;
    }
}

@media (max-width: 767px) {
.program-feature-wrap .vc_col-sm-3  {
    border-bottom: 2px solid #000000;
    border-right: none;
    text-align: center;
}
 
}


.placement .wptww-testimonial-content .wptww-testimonials-text {
    min-height: 25px;
}

.placement em, i {
    font-style: normal;
}

.placement1 .wptww-testimonial-inner {
    background-color: white;
    border-radius: 20px;
}
}

@media (min-width: 992px) {
  .vc_col-sm-2.custom-narrow-column {
    flex: 0 0 1% !important;
    max-width: 1% !important;
    padding-left: 0px;
    padding-right: 0px;
  }
}

.video-card1 .vc_col-sm-4 {
  max-width: 380px;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 6px 18px rgba(0,0,0,0.1);
  background: #fff;
  margin: 15px auto;
  transition: all 0.3s ease;
  border: 1px solid #4d4d4d;
}

/* Inner column settings */
.video-card1 .vc_column_container > .vc_column-inner {
  box-sizing: border-box;
  padding-left: 0px;
  padding-right: 0px;
  width: 100%;
}

/* Gap between inner content inside the card */
.video-card1 .wpb_wrapper > div {
  margin-bottom: 10px;
}

/* Mobile-specific adjustments */
@media (max-width: 768px) {
  .video-card1 .vc_col-sm-4 {
    width: 100% !important;
    margin: 20px 0; /* top and bottom spacing between cards */
  }

  .video-card1 {
    display: flex;
    flex-direction: column;
    gap: 20px; /* extra spacing between stacked cards */
  }
}

.cards-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
  padding: 16px 0;
}

.course-card {
  border-radius: 12px;
  overflow: hidden;
  background: #fff;
  border: 1px solid #4d4d4d;
  display: flex;
  flex-direction: column;
  transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
}

.course-card:hover {
  transform: translateY(-6px) scale(1.02);
  box-shadow: 0 12px 32px rgba(0,0,0,0.12);
  border-color: #888;
}

.card-img-wrap {
  overflow: hidden;
}

.course-card img {
  width: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.35s ease;
}

.course-card:hover img {
  transform: scale(1.05);
}

.card-body {
  padding: 12px 15px;
  display: flex;
  flex-direction: column;
  flex: 1;
  gap: 8px;
}

.card-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.badge {
  background-color: #4d4d4d;
  color: #fff;
  padding: 4px 10px;
  font-family: 'Roboto', sans-serif;
  border-radius: 25px;
  font-size: 12px;
  font-weight: 200;
}

.duration {
  font-size: 13px;
  font-family: 'Roboto', sans-serif;
  color: #666;
}

.card-title {
  font-size: 16px;
  font-weight: 400;
  font-family: 'Roboto', sans-serif;
  color: #000;
  margin: 0;
  line-height: 1.4;
}

.card-title strong {
  font-size: 21px;
  font-weight: 600;
  display: block;
}

.card-assoc {
  font-size: 15px;
  color: #666;
  font-family: 'Roboto', sans-serif;
  margin: 0;
  flex: 1;
}

.apply-btn {
  display: block;
  width: 100%;
  box-sizing: border-box;
  margin-top: 8px;
  padding: 8px 18px;
  background-color: #4d4d4d;
  color: #fff !important;
  border-radius: 6px;
  font-family: 'Roboto', sans-serif;
  font-size: 16px;
  font-weight: 400;
  text-decoration: none;
  text-align: center;
  transition: background-color 0.18s ease, transform 0.15s ease;
}

.apply-btn:hover {
  background-color: #333;
  transform: scale(1.03);
}

.apply-btn:active {
  transform: scale(0.97);
}

@media (max-width: 768px) {
  .cards-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 10px;
  }
  .card-meta { display: none; }
  .card-body { padding: 8px 10px; gap: 4px; }
  .card-title { font-size: 12px; }
  .card-title strong { font-size: 13px; }
  .card-assoc { font-size: 11px; }
  .apply-btn { font-size: 12px; padding: 6px 10px; margin-top: 4px; }
}


/* ── Marquee Logos ───────────────────────────────────────── */
.mq-wrap {
  display: flex;
  flex-direction: column;
  gap: 12px;
  overflow: hidden;
  width: 100%;
}

.mq-row {
  display: flex;
  overflow: hidden;
  width: 100%;
}

.mq-track {
  display: flex;
  gap: 4px;
  animation: mq-slide linear infinite;
  will-change: transform;
}

.mq-rev .mq-track {
  animation-direction: reverse;
}

.mq-row:hover .mq-track {
  animation-play-state: paused;
}

@keyframes mq-slide {
  0%   { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}

.mq-track div {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  padding: 0 3px;
}

.mq-track img {
  height: 119px;
  width: auto;
  max-width: 100%;
  object-fit: contain;
  display: block;
}

 .mq-row .mq-track     { animation-duration: 10s !important; }
  .mq-row.mq-rev .mq-track { animation-duration: 10s !important; }

/* ── Tablet ──────────────────────────────────────────────── */
@media (max-width: 768px) {
  .mq-wrap { gap: 6px; }
  .mq-track { gap: 6px; }
  .mq-track div {
    padding: 0 2px;
    width: calc(30vw - 10px); /* exactly 4 per screen */
  }
  .mq-track img {
    height: auto !important;
    width: 100% !important;
    max-height: 60px;
    object-fit: contain;
  }
  /* faster on tablet */
  .mq-row .mq-track     { animation-duration: 80s !important; }
  .mq-row.mq-rev .mq-track { animation-duration: 80s !important; }
}

/* ── Mobile ──────────────────────────────────────────────── */
@media (max-width: 480px) {
  .mq-track { gap: 4px; }
  .mq-track div {
    padding: 0 1px;
    width: calc(30vw - 8px); /* exactly 4 per screen */
  }
  .mq-track img {
    height: auto !important;
    width: 100% !important;
    max-height: 64px;
    object-fit: contain;
  }
  /* faster on mobile */
  .mq-row .mq-track         { animation-duration: 80s !important; }
  .mq-row.mq-rev .mq-track  { animation-duration: 80s !important; }
}


/* ── Differentiator rows (left column) ─────────────────────── */
.wr-differentiator {
  display: flex;
  gap: 1.25rem;
  padding: 1.4rem 0;
  border-bottom: 1px solid rgba(10,22,40,0.1);
}
.wr-differentiator:last-child {
  border-bottom: none;
}
.wr-diff-num {
  font-family: 'Roboto', system-ui, sans-serif;
  font-size: 45px;
  font-weight: 700;
  color: rgba(0,0,0,0.25);
  line-height: 1;
  min-width: 44px;
  flex-shrink: 0;
}
.wr-diff-title {
  font-family: 'Roboto', system-ui, sans-serif;
  font-size: 18px;
  font-weight: 700;
  margin-bottom: 0.4rem;
    color: #000!important;
}
.wr-diff-desc {
  font-size: 15px;
  line-height: 1.2;
  font-weight: 400;
    color: #000!important;
}

/* ── Comparison table (right column) ───────────────────────── */
.wr-compare-lbl {
  font-family: 'Roboto', system-ui, sans-serif;
  font-size: 18px;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  margin-bottom: 1rem;
    padding: 1.4rem 0;
    color: #000!important;
}
.wr-compare-table {
  width: 100%;
  border-collapse: collapse;
  border: 1px solid rgba(10,22,40,0.1);
  border-radius: 12px;
  overflow: hidden;
  font-family: 'Roboto', system-ui, sans-serif;
}
.wr-compare-table th {
  font-family: 'Roboto', system-ui, sans-serif;
  font-size: 15px;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 0.75rem 1rem;
  background: rgba(10,22,40,0.04);
  color: #64748B;
  text-align: left;
  border-bottom: 1px solid rgba(10,22,40,0.08);
    color: #000!important;
}
.wr-compare-table th:not(:first-child) { text-align: center; }
.wr-compare-table td {
  padding: 0.82rem 1rem;
  font-size: 15px;
color: #000!important;
    border-bottom: 1px solid rgba(10,22,40,0.07);
  vertical-align: middle;
  font-family: 'Roboto', system-ui, sans-serif;
}
.wr-compare-table tr:last-child td { border-bottom: none; }
.wr-compare-table td:not(:first-child) { text-align: center; }
.wr-compare-table td:first-child { font-weight: 500; color: #000!important; }
.wr-race-col  { color: #f0712f; !important; font-weight: 700 !important; }
.wr-race-head { background: rgba(201,168,76,0.08) !important; color: #f0712f; !important; }
